      "sections_used": [
        "S02",
        "S03"
      ],
      "graceful_degradation": "show_last_known",
      "column_map": {
        "Month": "month",
        "Entity": "entity",
        "Target Type": "target_type",
        "Dues Target": "dues_target_aed",
        "Dues Actual": "dues_actual_aed",
        "Advance Target": "advance_target_aed",
        "Advance Actual": "advance_actual_aed",
        "D+A Target": "da_target_aed",
        "D+A Actual": "da_actual_aed",
        "Achievement%": "achievement_pct"
      },
      "column_types": {
        "month": "datetime",
        "entity": "str",
        "target_type": "str",
        "dues_target_aed": "float",
        "dues_actual_aed": "float",
        "advance_target_aed": "float",
        "advance_actual_aed": "float",
        "da_target_aed": "float",
        "da_actual_aed": "float",
        "achievement_pct": "float"
      },
      "aggregations": {
        "fy_dues_target_group": {
          "op": "filter_sum",
          "col": "dues_target_aed",
          "filter": {
            "entity": "Group"
          }
        },
        "fy_advance_target_group": {
          "op": "filter_sum",
          "col": "advance_target_aed",
          "filter": {
            "entity": "Group"
          }
        },
        "q1_dues_actual_group": {
          "op": "filter_sum",
          "col": "dues_actual_aed",
          "filter": {
            "entity": "Group",
            "month_in": [
              "2026-01",
              "2026-02",
              "2026-03"
            ]
          }
        },
        "q1_advance_actual_group": {
          "op": "filter_sum",
          "col": "advance_actual_aed",
          "filter": {
            "entity": "Group",
            "month_in": [
              "2026-01",
              "2026-02",
              "2026-03"
            ]
          }
        }
      }
    },
    "R04": {
