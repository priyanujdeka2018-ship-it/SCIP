  "sources": {
    "R01": {
      "id": "R01",
      "label": "Year-End Collections Snapshot 2021-2025",
      "file": "R01_year_end_snap.xlsx",
      "sheet_name": 0,
      "file_type": "xlsx",
      "granularity": "annual",
      "data_date": "2026-03",
      "sections_used": [
        "S01"
      ],
      "graceful_degradation": "show_last_known",
      "column_map": {
        "Year": "year",
        "Entity": "entity",
        "Dues": "dues_aed",
        "Advance": "advance_aed",
        "New Sales": "new_sales_aed",
        "D+A": "total_da_aed",
        "Total Collections": "total_collections_aed",
        "LP Charges": "lp_charges_aed"
      },
      "column_types": {
        "year": "int",
        "entity": "str",
        "dues_aed": "float",
        "advance_aed": "float",
        "new_sales_aed": "float",
        "total_da_aed": "float",
        "total_collections_aed": "float",
        "lp_charges_aed": "float"
      },
      "aggregations": {
        "da_cagr_anchor_2021": {
          "op": "filter_sum",
          "col": "total_da_aed",
          "filter": {
            "year": 2021,
            "entity": "Group"
          }
        },
        "da_cagr_anchor_2025": {
          "op": "filter_sum",
          "col": "total_da_aed",
          "filter": {
            "year": 2025,
            "entity": "Group"
          }
        },
        "total_2025_group": {
          "op": "filter_sum",
          "col": "total_collections_aed",
          "filter": {
            "year": 2025,
            "entity": "Group"
          }
        },
        "lp_growth_2021": {
          "op": "filter_sum",
          "col": "lp_charges_aed",
          "filter": {
            "year": 2021,
            "entity": "Group"
          }
        },
        "lp_growth_2025": {
          "op": "filter_sum",
          "col": "lp_charges_aed",
          "filter": {
            "year": 2025,
            "entity": "Group"
          }
        }
      }
    },
    "R02": {
