    "purpose": "Column mappings and aggregation rules per R-series source.",
    "edit_rule": "Only Priyanuj or Claude edits this file.",
    "format_rule": "All source files are xlsx. openpyxl reads them.",
    "unit_rule": "All monetary output from data_loader is in AED base units (not millions).",
    "naming_convention": "snake_case throughout. _aed suffix = AED base units. _pct suffix = 0-100 scale.",
    "changelog": {
      "v7": "R18 entry fully rebuilt. Positional column reads. Grand Total row for OD_TODAY. Sub Total rows A-E/F/G for entity OD."
