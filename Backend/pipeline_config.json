          "op": "sum",
          "col": "dues_aed"
        },
        "mtd_advance_total": {
          "op": "sum",
          "col": "advance_aed"
        },
        "mtd_ns_total": {
          "op": "sum",
          "col": "new_sales_aed"
        }
      }
    },
    "R08": {
      "id": "R08",
      "label": "Advance Collections Summary \u2014 CY/FY Splits, Rebate, NPV",
      "file": "R08_advance_summary.xlsx",
      "sheet_name": "Summary",
      "file_type": "xlsx",
      "granularity": "monthly",
      "data_date_col": "month",
      "sections_used": [
        "S01",
        "S05"
      ],
      "graceful_degradation": "show_last_known",
      "column_map": {
        "Month": "month",
        "Year": "year",
        "Entity": "entity",
        "CY Advance": "cy_advance_aed",
        "FY Advance": "fy_advance_aed",
        "Total Advance": "total_advance_aed",
        "CY Mix%": "cy_mix_pct",
        "Rebate": "rebate_aed",
        "Rebate Rate%": "rebate_rate_pct",
        "Avg Lead Days": "avg_advance_lead_days",
        "NPV Rate%": "npv_rate_pct"
      },
      "column_types": {
        "month": "datetime",
        "year": "int",
        "entity": "str",
        "cy_advance_aed": "float",
        "fy_advance_aed": "float",
        "total_advance_aed": "float",
        "cy_mix_pct": "float",
        "rebate_aed": "float",
        "rebate_rate_pct": "float",
        "avg_advance_lead_days": "float",
        "npv_rate_pct": "float"
      },
      "aggregations": {
        "CY_ADV_MIX_YTD": {
          "op": "weighted_avg",
          "numerator": "cy_advance_aed",
          "denominator": "total_advance_aed",
          "filter": {
            "year": 2026,
            "entity": "Group"
          },
          "multiply_100": true
        },
        "AVG_ADVANCE_LEAD_DAYS": {
          "op": "mean",
          "col": "avg_advance_lead_days",
          "filter": {
            "entity": "Group"
          }
        },
        "advance_2025_total": {
          "op": "filter_sum",
          "col": "total_advance_aed",
          "filter": {
            "year": 2025,
            "entity": "Group"
          }
        },
        "ytd_2026_rebate": {
          "op": "filter_sum",
          "col": "rebate_aed",
          "filter": {
            "year": 2026,
            "entity": "Group"
          }
        },
        "ytd_2026_advance": {
          "op": "filter_sum",
          "col": "total_advance_aed",
          "filter": {
            "year": 2026,
            "entity": "Group"
          }
        }
      }
    },
