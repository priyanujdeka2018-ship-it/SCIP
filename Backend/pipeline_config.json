        "Working Day": "working_day_no",
        "Dues": "dues_aed",
        "Advance": "advance_aed",
        "D+A": "da_aed",
        "New Sales": "new_sales_aed",
        "DLD": "dld_aed",
        "D+A MTD": "da_mtd_aed",
