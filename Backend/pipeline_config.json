    "R18": {
      "id": "R18",
      "label": "Consolidated & Overdue \u2014 Master OD Report (SINGLE SOURCE OF TRUTH)",
      "file": "R18_consolidated_overdue.xlsx",
      "sheet_name": "Overdue-1",
      "file_type": "xlsx",
      "granularity": "positional_rows",
      "sections_used": [
        "S02",
        "S04",
        "S08"
      ],
      "graceful_degradation": "show_last_known",
      "authority": "Single source of truth for all OD figures.",
      "_read_strategy": "POSITIONAL \u2014 scan row labels in col[0]. openpyxl data_only=True.",
      "sheet_structure": {
        "active_sheet": "Overdue-1",
        "read_mode": "positional_row_scan",
        "header_date_cell": "Read snapshot date from header cell row 0 or 1."
      },
      "positional_columns": {
        "col_0": "row_label",
        "col_8": "ageing_0_30_aed",
        "col_9": "ageing_31_60_aed",
        "col_10": "ageing_61_90_aed",
        "col_11": "ageing_91_120_aed",
        "col_12": "ageing_121_180_aed",
        "col_13": "ageing_180plus_aed",
        "col_14": "total_od_aed"
      },
      "row_identification": {
        "grand_total_row": {
          "match_col": 0,
          "match_value": "Grand Total",
          "match_strategy": "str_contains_case_insensitive",
          "reads": [
            "col_8",
            "col_9",
            "col_10",
            "col_11",
            "col_12",
            "col_13",
            "col_14"
          ],
          "produces": [
            "OD_TODAY",
            "ageing_0_30",
            "ageing_31_60",
            "ageing_61_90",
            "ageing_91_120",
            "ageing_121_180",
            "ageing_180plus"
          ]
        },
        "sobha_subtotals": {
          "match_col": 0,
          "match_values": [
            "Sub Total (A)",
            "Sub Total (B)",
            "Sub Total (C)",
            "Sub Total (D)",
            "Sub Total (E)"
          ],
          "match_strategy": "str_exact_case_insensitive",
          "reads": [
            "col_14"
          ],
          "aggregation": "sum",
          "produces": "OD_SOBHA"
        },
        "siniya_subtotal": {
          "match_col": 0,
          "match_value": "Sub Total (F)",
          "match_strategy": "str_exact_case_insensitive",
          "reads": [
            "col_14"
          ],
          "produces": "OD_SINIYA"
        },
        "dt_subtotal": {
          "match_col": 0,
          "match_value": "Sub Total (G)",
          "match_strategy": "str_exact_case_insensitive",
          "reads": [
            "col_14"
          ],
          "produces": "OD_DT"
        }
      },
      "aggregations": {
        "OD_TODAY": {
          "source_row": "grand_total_row",
          "source_col": "col_14",
          "validated_value": 1650100000,
          "validated_as_of": "2026-03-15"
        },
        "OD_SOBHA": {
          "source_rows": "sobha_subtotals",
          "source_col": "col_14",
          "aggregation": "sum",
          "validated_value": 1472700000,
          "validated_as_of": "2026-03-15"
        },
        "OD_SINIYA": {
          "source_row": "siniya_subtotal",
          "source_col": "col_14",
          "validated_value": 166400000,
          "validated_as_of": "2026-03-15"
        },
        "OD_DT": {
          "source_row": "dt_subtotal",
          "source_col": "col_14",
          "validated_value": 11000000,
          "validated_as_of": "2026-03-15"
        },
        "SNAPSHOT_DATE": {
          "op": "read_header_cell",
          "sheet": "Overdue-1",
          "strategy": "scan_first_2_rows_for_date"
        },
        "ageing_0_30": {
          "source_row": "grand_total_row",
          "source_col": "col_8",
          "validated_value": 830000000
        },
        "ageing_31_60": {
          "source_row": "grand_total_row",
          "source_col": "col_9",
          "validated_value": 445000000
        },
        "ageing_61_90": {
          "source_row": "grand_total_row",
          "source_col": "col_10",
          "validated_value": 166000000
        },
        "ageing_91_120": {
          "source_row": "grand_total_row",
          "source_col": "col_11",
          "validated_value": 79000000
        },
        "ageing_121_180": {
          "source_row": "grand_total_row",
          "source_col": "col_12",
          "validated_value": 47000000
        },
        "ageing_180plus": {
          "source_row": "grand_total_row",
          "source_col": "col_13",
          "validated_value": 225000000
        }
      },
      "validation_check": {
        "rule": "OD_SOBHA + OD_SINIYA + OD_DT must equal OD_TODAY +/- 0.1M",
        "formula": "1,472.7M + 166.4M + 11.0M = 1,650.1M",
        "on_fail": "Log warning. Surface OD reconciliation gap label. Do not crash."
      }
    },
